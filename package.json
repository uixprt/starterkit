{
  "name": "@a/starterkit",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "modules/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @a/app",
    "build": "npm run build -w @a/design-system && npm run build -w @a/module-header && npm run build -w @a/app",
    "pack:all": "npm run pack -ws --if-present"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
